---
import BaseLayout from './BaseLayout.astro';
import { useTranslations, formatDate } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  author: string;
  publishDate: Date;
  image: string;
  downloadUrl?: string;
  downloadLabel?: string;
  buyUrl?: string;
  lang: Lang;
}

const { title, author, publishDate, image, downloadUrl, downloadLabel, buyUrl, lang } = Astro.props;
const t = useTranslations(lang);

const schema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": title,
  "author": { "@type": "Person", "name": author },
  "datePublished": publishDate.toISOString().split('T')[0],
  "image": new URL(image, Astro.site).href,
  "inLanguage": lang,
};
---

<BaseLayout title={title} image={image} description={`${title} — ${author}. ${t('site.title')}`}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <article class="book-detail">
    <div class="book-detail__top">
      <div class="book-detail__info">
        <header class="book-detail__header">
          <h1>{title}</h1>
          <p class="book-detail__meta">
            <span>{t('book.author')}: <strong>{author}</strong></span>
            <span>{t('book.date')}: {formatDate(publishDate, lang)}</span>
          </p>
        </header>

        <div class="book-detail__content">
          <slot />
        </div>

        <div class="book-detail__actions">
          {downloadUrl && (
            <a href={downloadUrl} target="_blank" rel="noopener noreferrer" class="btn">
              {downloadLabel || t('book.download')}
            </a>
          )}
          {buyUrl && (
            <a href={buyUrl} target="_blank" rel="noopener noreferrer" class="btn">
              {t('book.buy')}
            </a>
          )}
        </div>
      </div>

      <img src={image} alt={title} class="book-detail__cover" />
    </div>
  </article>
</BaseLayout>

<style>
  .book-detail__top {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
  }

  .book-detail__info {
    flex: 1;
    min-width: 0;
  }

  .book-detail__header {
    margin-bottom: 1.5rem;
  }

  .book-detail__meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    color: var(--color-text);
    font-style: italic;
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }

  .book-detail__cover {
    width: 280px;
    flex-shrink: 0;
    border-radius: 4px;
  }

  .book-detail__content {
    margin-bottom: 1.5rem;
  }

  .book-detail__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .book-detail__top {
      flex-direction: column;
    }

    .book-detail__cover {
      width: 100%;
      max-width: 400px;
    }
  }
</style>
