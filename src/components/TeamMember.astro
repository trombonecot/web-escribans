---
interface Props {
  name: string;
  image: string;
  role: string;
  bio: string;
}

const { name, image, role, bio } = Astro.props;
---

<article class="team-member">
  <img src={image} alt={name} class="team-member__photo" loading="lazy" />
  <div class="team-member__info">
    <h3 class="team-member__name">{name}</h3>
    <p class="team-member__role">{role}</p>
    <div class="team-member__bio" set:html={bio} />
  </div>
</article>

<style>
  .team-member {
    margin-bottom: 3rem;
  }

  .team-member__photo {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1rem;
  }

  .team-member__name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .team-member__role {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    font-style: italic;
    margin-bottom: 1rem;
  }
</style>
