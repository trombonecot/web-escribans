---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('nav.contact')} description="Contacta amb els Escrivans de l'Hipogeu per encàrrecs, col·laboracions o qualsevol consulta.">
  <h2 class="page-title">{t('nav.contact')}</h2>
  <p>
    {t('contact.intro')}
    <a href="mailto:escrivans@hipogeu.org">escrivans@hipogeu.org</a>.
  </p>
</BaseLayout>
