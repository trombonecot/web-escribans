---
import BaseLayout from '../layouts/BaseLayout.astro';

const url = Astro.url.pathname;
const lang = url.startsWith('/es') ? 'es' : 'ca';

const content = {
  ca: {
    title: '404 - Pàgina no trobada',
    message: 'La pàgina que busques no existeix o ha estat moguda.',
    button: 'Torna a l\'inici',
    home: '/ca/',
  },
  es: {
    title: '404 - Página no encontrada',
    message: 'La página que buscas no existe o ha sido movida.',
    button: 'Volver al inicio',
    home: '/es/',
  },
};

const t = content[lang];
---

<BaseLayout title={t.title}>
  <section class="error-page">
    <h1>{t.title}</h1>
    <p>{t.message}</p>
    <a href={t.home} class="btn">{t.button}</a>
  </section>
</BaseLayout>

<style>
  .error-page {
    text-align: center;
    padding: 4rem 1rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .error-page h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .error-page p {
    font-size: 1.2rem;
    margin-bottom: 2rem;
  }

  .error-page .btn {
    display: inline-block;
    background-color: #000;
    color: #fee873;
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    font-weight: 600;
    border-radius: 4px;
    transition: opacity 0.2s;
  }

  .error-page .btn:hover {
    opacity: 0.85;
  }
</style>
